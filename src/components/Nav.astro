---
const base = import.meta.env.BASE_URL;
---
<nav class="site-nav">
  <a href={base} class="logo" aria-label="Parent un jour">
    Parent <span class="un-jour">un jour</span>
  </a>

  <button
    type="button"
    class="nav-toggle"
    aria-label="Ouvrir le menu"
    aria-expanded="false"
    aria-controls="site-menu"
  >
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
  </button>

  <ul id="site-menu" class="nav-menu">
    <li><a href={base}>Accueil</a></li>
    <li class="has-dd">
      <a href={`${base}#axes`} class="dd-trigger">
        Le village <span class="chev" aria-hidden="true">▾</span>
      </a>
      <div class="dd-panel">
        <a href={`${base}le-village/creer-son-village/`} class="dd-item">
          <div class="dd-title">Créer son village</div>
          <div class="dd-sub">avant bébé, s'entourer</div>
        </a>
        <a href={`${base}le-village/couple-coparent/`} class="dd-item">
          <div class="dd-title">Couple &amp; coparent</div>
          <div class="dd-sub">s'organiser, se parler, charge mentale</div>
        </a>
        <a href={`${base}le-village/postnatal/`} class="dd-item">
          <div class="dd-title">Le postnatal</div>
          <div class="dd-sub">la matrescence, devenir parent</div>
        </a>
      </div>
    </li>
    <li><a href={`${base}le-journal/`}>Le journal</a></li>
    <li><a href={`${base}ressources/`}>Ressources</a></li>
    <li><a href="https://www.instagram.com/parentunjour" class="cta-nav" target="_blank" rel="noopener">Me suivre</a></li>
  </ul>
</nav>

<script is:inline>
  (() => {
    const nav = document.querySelector('.site-nav');
    const toggle = nav?.querySelector('.nav-toggle');
    const menu = document.getElementById('site-menu');
    if (!nav || !toggle || !menu) return;

    const MOBILE_BREAKPOINT = 900;
    const isMobile = () => window.innerWidth <= MOBILE_BREAKPOINT;

    // Toggle hamburger (mobile only)
    toggle.addEventListener('click', () => {
      const open = nav.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
    });

    // Close menu when a link is tapped (mobile)
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        if (isMobile() && !link.classList.contains('dd-trigger')) {
          nav.classList.remove('is-open');
          toggle.setAttribute('aria-expanded', 'false');
        }
      });
    });

    // Dropdown: on mobile, click "Le village" toggles sub-menu
    const ddTrigger = nav.querySelector('.has-dd > .dd-trigger');
    const ddParent = ddTrigger?.parentElement;
    if (ddTrigger && ddParent) {
      ddTrigger.addEventListener('click', (e) => {
        if (isMobile()) {
          e.preventDefault();
          ddParent.classList.toggle('is-open');
        }
      });
    }

    // If user resizes to desktop while menu was open → close
    window.addEventListener('resize', () => {
      if (!isMobile()) {
        nav.classList.remove('is-open');
        ddParent?.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>
