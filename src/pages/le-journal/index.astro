---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { PILIERS } from '../../content.config';

const base = import.meta.env.BASE_URL;

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const featured = posts.find((p) => p.data.featured);
const others = posts.filter((p) => p !== featured);

const formatDate = (d: Date) =>
  d.toLocaleDateString('fr-CA', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout
  title="Le journal — Parent un jour"
  description="Le journal de Parent un jour — articles sourcés scientifiquement sur la préparation au village, le couple après bébé, le postnatal et la parentalité au Québec."
>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-inner">
      <div class="label">Parent un jour</div>
      <h1>Le journal du village</h1>
      <div class="script-line">ici, on parle pour vrai</div>
      <p class="tagline">
        Un espace où on aborde les vraies questions de la parentalité — sans filtre,
        sans jugement, avec des sources. Chaque article est pensé pour t'accompagner
        là où tu en es.
      </p>
    </div>
  </section>

  <!-- ===== FEATURED ARTICLE ===== -->
  {featured && (
    <section class="journal-featured">
      <div class="container">
        <div class="section-label key">À la une</div>
        <a href={`${base}le-journal/${featured.id}/`} class="featured-card">
          <div class="featured-thumb" data-axis={featured.data.axis}>
            <span class="featured-emoji">{featured.data.thumbnailEmoji}</span>
          </div>
          <div class="featured-content">
            <div class="tag-cat">{featured.data.piliers[0]}</div>
            <h2>{featured.data.title}</h2>
            <p>{featured.data.description}</p>
            <span class="article-read">Lire l'article →</span>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- ===== FILTRES (par pilier) ===== -->
  <section class="journal-filters">
    <div class="container">
      <div class="filter-bar" role="tablist" aria-label="Filtrer les articles par pilier">
        <button type="button" class="filter-tab active" data-filter="all" role="tab" aria-selected="true">Tous</button>
        {PILIERS.map((pilier) => (
          <button type="button" class="filter-tab" data-filter={pilier} role="tab" aria-selected="false">{pilier}</button>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== GRILLE D'ARTICLES ===== -->
  <section class="journal-list">
    <div class="container">
      {others.length > 0 ? (
        <div class="journal-grid">
          {others.map((post) => (
            <a
              href={`${base}le-journal/${post.id}/`}
              class="journal-card"
              data-piliers={post.data.piliers.join('|')}
            >
              <div class="journal-thumb" data-axis={post.data.axis}>
                <span class="journal-emoji">{post.data.thumbnailEmoji}</span>
              </div>
              <div class="journal-card-body">
                <div class="tag-cat">{post.data.piliers[0]}</div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <div class="journal-meta-line">
                  <time datetime={post.data.publishDate.toISOString()}>{formatDate(post.data.publishDate)}</time>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        !featured && (
          <p class="journal-empty">Aucun article publié pour le moment — les premiers arrivent bientôt.</p>
        )
      )}
      <p class="journal-empty" id="journal-no-results" hidden>
        Aucun article pour ce pilier pour le moment.
      </p>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-section">
    <div class="container">
      <h2>Ne manque rien du journal</h2>
      <div class="script">un article à la fois.</div>
      <p>
        Suis Parent un jour sur Instagram pour être averti·e des nouveaux articles —
        et rejoins une communauté de parents qui osent parler vrai.
      </p>
      <div class="cta-buttons">
        <a href="https://www.instagram.com/parentunjour" class="btn btn-primary" target="_blank" rel="noopener">Me suivre sur Instagram</a>
        <a href={`${base}rss.xml`} class="btn btn-outline">Flux RSS</a>
      </div>
    </div>
  </section>

</Layout>

<script is:inline>
  const noResults = document.getElementById('journal-no-results');
  document.querySelectorAll('.filter-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const filter = tab.dataset.filter;

      document.querySelectorAll('.filter-tab').forEach((t) => {
        t.classList.toggle('active', t === tab);
        t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
      });

      let visibleCount = 0;
      document.querySelectorAll('.journal-card').forEach((card) => {
        const piliers = (card.dataset.piliers || '').split('|');
        const match = filter === 'all' || piliers.includes(filter);
        card.style.display = match ? '' : 'none';
        if (match) visibleCount++;
      });

      // Affiche/masque le message "aucun résultat"
      if (noResults) {
        noResults.hidden = filter === 'all' || visibleCount > 0;
      }
    });
  });
</script>
