---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { PILIERS } from '../../content.config';

const base = import.meta.env.BASE_URL;

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const featured = posts.find((p) => p.data.featured);
const others = posts.filter((p) => p !== featured);

const formatMonthYear = (d: Date) =>
  d.toLocaleDateString('fr-CA', { year: 'numeric', month: 'long' })
    .replace(/^./, (c) => c.toUpperCase());
---
<Layout
  title="Le journal du village — Parent un jour"
  description="Le journal de Parent un jour — articles sourcés sur la parentalité, écrits avec soin. Pour les 3 h du matin comme pour les dimanches tranquilles."
>

  <!-- ===== HEADER JOURNAL ===== -->
  <header class="journal-header">

    <!-- Motif botanique organique en background (full-width) -->
    <svg class="botanical" viewBox="0 0 1200 400" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <!-- Branche gauche -->
      <path d="M -20 380 C 30 340, 60 300, 80 250 C 100 200, 90 160, 100 120 C 110 80, 130 50, 140 10" stroke="#83967D" stroke-width="2" stroke-linecap="round" fill="none"/>
      <path d="M -10 390 C 20 350, 40 310, 55 270 C 70 230, 65 190, 75 150 C 85 110, 100 70, 105 30" stroke="#83967D" stroke-width="1.2" stroke-linecap="round" fill="none" opacity="0.6"/>
      <path d="M 80 250 C 50 240, 28 225, 22 210 C 36 205, 58 218, 76 242" fill="#83967D" opacity="0.5"/>
      <path d="M 90 190 C 60 182, 38 168, 34 154 C 46 150, 66 162, 86 182" fill="#83967D" opacity="0.4"/>
      <path d="M 100 130 C 74 122, 56 108, 52 96 C 62 93, 80 104, 96 122" fill="#83967D" opacity="0.35"/>
      <path d="M 85 260 C 110 252, 132 238, 138 224 C 126 220, 106 232, 88 252" fill="#83967D" opacity="0.4"/>
      <path d="M 95 200 C 120 192, 140 178, 146 164 C 134 160, 114 172, 98 192" fill="#83967D" opacity="0.35"/>
      <path d="M 105 140 C 128 132, 146 118, 150 106 C 140 103, 122 114, 108 132" fill="#83967D" opacity="0.3"/>
      <circle cx="78" cy="245" r="6" fill="#A8B9A3" opacity="0.6"/>
      <circle cx="88" cy="185" r="5" fill="#A8B9A3" opacity="0.5"/>
      <circle cx="98" cy="128" r="5" fill="#A8B9A3" opacity="0.45"/>
      <circle cx="106" cy="75" r="4" fill="#A8B9A3" opacity="0.35"/>
      <circle cx="68" cy="215" r="3.5" fill="#D9E1D4" opacity="0.5"/>
      <circle cx="100" cy="160" r="3" fill="#D9E1D4" opacity="0.45"/>

      <!-- Branche droite -->
      <path d="M 1220 370 C 1170 330, 1140 290, 1120 240 C 1100 190, 1110 150, 1100 110 C 1090 70, 1070 40, 1060 5" stroke="#83967D" stroke-width="2" stroke-linecap="round" fill="none"/>
      <path d="M 1210 380 C 1175 345, 1155 310, 1140 265 C 1125 220, 1135 180, 1125 140 C 1115 100, 1095 65, 1085 25" stroke="#83967D" stroke-width="1.2" stroke-linecap="round" fill="none" opacity="0.6"/>
      <path d="M 1120 240 C 1150 232, 1172 218, 1178 204 C 1164 200, 1144 212, 1124 232" fill="#83967D" opacity="0.5"/>
      <path d="M 1105 180 C 1135 172, 1156 158, 1162 144 C 1148 140, 1128 152, 1108 172" fill="#83967D" opacity="0.4"/>
      <path d="M 1100 120 C 1126 112, 1144 98, 1148 86 C 1138 83, 1120 94, 1104 112" fill="#83967D" opacity="0.35"/>
      <path d="M 1125 250 C 1095 242, 1074 228, 1068 214 C 1080 210, 1100 222, 1122 242" fill="#83967D" opacity="0.4"/>
      <path d="M 1110 190 C 1082 182, 1062 168, 1058 154 C 1068 150, 1088 162, 1106 182" fill="#83967D" opacity="0.35"/>
      <circle cx="1118" cy="235" r="6" fill="#A8B9A3" opacity="0.6"/>
      <circle cx="1108" cy="175" r="5" fill="#A8B9A3" opacity="0.5"/>
      <circle cx="1098" cy="118" r="5" fill="#A8B9A3" opacity="0.45"/>
      <circle cx="1090" cy="65" r="4" fill="#A8B9A3" opacity="0.35"/>
      <circle cx="1130" cy="210" r="3.5" fill="#D9E1D4" opacity="0.5"/>
      <circle cx="1105" cy="148" r="3" fill="#D9E1D4" opacity="0.45"/>

      <!-- Décos centrales -->
      <path d="M 500 400 C 510 370, 520 350, 515 330" stroke="#A8B9A3" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.4"/>
      <path d="M 515 330 C 500 322, 490 314, 488 306" fill="#83967D" opacity="0.2"/>
      <path d="M 515 330 C 528 320, 538 312, 540 304" fill="#83967D" opacity="0.2"/>
      <circle cx="514" cy="328" r="3.5" fill="#A8B9A3" opacity="0.35"/>
      <path d="M 700 400 C 695 375, 688 355, 692 335" stroke="#A8B9A3" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.4"/>
      <path d="M 692 335 C 678 328, 668 320, 666 312" fill="#83967D" opacity="0.2"/>
      <path d="M 692 335 C 704 326, 714 318, 716 310" fill="#83967D" opacity="0.2"/>
      <circle cx="691" cy="333" r="3.5" fill="#A8B9A3" opacity="0.35"/>
    </svg>

    <div class="inner">
      <div class="top-row">
        <h1>Le journal du village</h1>
        <span class="cursive-tag">lire, comprendre, se retrouver</span>
      </div>
      <p class="subtitle">
        Des articles sourcés sur la parentalité, écrits avec soin.
        Pour les 3&nbsp;h du matin comme pour les dimanches tranquilles.
      </p>
    </div>
  </header>

  <!-- ===== FILTERS BAR ===== -->
  <div class="filters-bar" role="tablist" aria-label="Filtrer les articles par pilier">
    <button type="button" class="filter-pill active" data-filter="all" role="tab" aria-selected="true">Tous</button>
    {PILIERS.map((pilier) => (
      <button type="button" class="filter-pill" data-filter={pilier} role="tab" aria-selected="false">{pilier}</button>
    ))}
    <button type="button" class="search-btn" aria-label="Rechercher (bientôt disponible)" title="Recherche — bientôt disponible" disabled>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    </button>
  </div>

  <!-- ===== ARTICLES GRID ===== -->
  <div class="articles-grid">

    {featured && (
      <a
        href={`${base}le-journal/${featured.id}/`}
        class="article-card featured"
        data-piliers={featured.data.piliers.join('|')}
      >
        <div class="card-img">{featured.data.thumbnailEmoji}</div>
        <div class="card-body">
          <div class="card-pilier">Article à la une</div>
          <div class="card-title">{featured.data.title}</div>
          <div class="card-excerpt">{featured.data.description}</div>
          <div class="card-meta">
            Par {featured.data.author} · {formatMonthYear(featured.data.publishDate)}
            {featured.data.readingTime && <> · {featured.data.readingTime}</>}
          </div>
        </div>
      </a>
    )}

    {others.map((post) => (
      <a
        href={`${base}le-journal/${post.id}/`}
        class="article-card"
        data-piliers={post.data.piliers.join('|')}
      >
        <div class="card-img">{post.data.thumbnailEmoji}</div>
        <div class="card-body">
          <div class="card-pilier">{post.data.piliers[0]}</div>
          <div class="card-title">{post.data.title}</div>
          <div class="card-excerpt">{post.data.description}</div>
          <div class="card-meta">
            {post.data.readingTime ? `${post.data.readingTime} de lecture` : formatMonthYear(post.data.publishDate)}
          </div>
        </div>
      </a>
    ))}

    {posts.length === 0 && (
      <p class="journal-empty">Aucun article publié pour le moment — les premiers arrivent bientôt.</p>
    )}
    <p class="journal-empty" id="journal-no-results" hidden>
      Aucun article pour ce pilier pour le moment.
    </p>
  </div>

  <!-- ===== CTA ===== -->
  <section class="cta-section">
    <div class="container">
      <h2>Ne manque rien du journal</h2>
      <div class="script">un article à la fois.</div>
      <p>
        Suis Parent un jour sur Instagram pour être averti·e des nouveaux articles —
        et rejoins une communauté de parents qui osent parler vrai.
      </p>
      <div class="cta-buttons">
        <a href="https://www.instagram.com/parentunjour" class="btn btn-primary" target="_blank" rel="noopener">Me suivre sur Instagram</a>
      </div>
    </div>
  </section>

</Layout>

<script is:inline>
  (() => {
    const noResults = document.getElementById('journal-no-results');
    const pills = document.querySelectorAll('.filter-pill');
    const cards = document.querySelectorAll('.articles-grid .article-card');

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const filter = pill.dataset.filter;

        pills.forEach((p) => {
          p.classList.toggle('active', p === pill);
          p.setAttribute('aria-selected', p === pill ? 'true' : 'false');
        });

        let visible = 0;
        cards.forEach((card) => {
          const piliers = (card.dataset.piliers || '').split('|');
          const match = filter === 'all' || piliers.includes(filter);
          card.style.display = match ? '' : 'none';
          if (match) visible++;
        });

        if (noResults) noResults.hidden = filter === 'all' || visible > 0;
      });
    });
  })();
</script>

<style>
  /* ===== HEADER JOURNAL ===== */
  .journal-header {
    padding: 200px 40px 120px;
    background: var(--cream);
    border-bottom: 3px solid var(--sage);
    position: relative;
    overflow: hidden;
  }
  .journal-header .botanical {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0.12;
    pointer-events: none;
  }
  .journal-header .inner {
    max-width: 960px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .journal-header .top-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 6px;
  }
  .journal-header h1 {
    font-family: 'Georgia', serif;
    font-size: clamp(26px, 3.5vw, 36px);
    font-weight: 400;
    color: var(--slate);
    line-height: 1.2;
  }
  .journal-header .cursive-tag {
    font-family: 'La Belle Aurore', cursive;
    color: var(--terra);
    font-size: 22px;
    flex-shrink: 0;
  }
  .journal-header .subtitle {
    font-size: 15px;
    color: var(--slate);
    opacity: 0.85;
    max-width: 560px;
    line-height: 1.6;
    margin-top: 2px;
  }

  /* ===== FILTERS BAR ===== */
  .filters-bar {
    max-width: 960px;
    margin: 0 auto;
    padding: 48px 40px 48px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 10px;
    flex-wrap: wrap;
  }
  .filter-pill {
    font-family: 'Lato', sans-serif;
    font-size: 12.5px;
    font-weight: 400;
    padding: 7px 16px;
    border-radius: 999px;
    border: 1px solid var(--sage-soft);
    color: var(--slate);
    opacity: 0.85;
    background: transparent;
    cursor: pointer;
    transition: all 0.25s;
    letter-spacing: 0.2px;
  }
  .filter-pill:hover {
    border-color: var(--sage);
    color: var(--slate);
    opacity: 1;
    background: var(--sage-light);
  }
  .filter-pill.active {
    background: var(--sage);
    color: var(--white);
    border-color: var(--sage);
    opacity: 1;
  }
  .search-btn {
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 1px solid var(--sage-soft);
    background: transparent;
    display: flex; align-items: center; justify-content: center;
    cursor: not-allowed;
    margin-left: auto;
    opacity: 0.6;
    color: var(--slate);
  }
  .search-btn svg {
    width: 15px; height: 15px;
  }

  /* ===== ARTICLES GRID ===== */
  .articles-grid {
    max-width: 960px;
    margin: 0 auto;
    padding: 32px 40px 96px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .articles-grid .article-card {
    background: var(--white);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 20px rgba(76, 88, 97, 0.06);
    border: 1px solid rgba(168, 185, 163, 0.15);
    transition: transform 0.3s, box-shadow 0.3s;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }
  .articles-grid .article-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(76, 88, 97, 0.1);
  }
  .articles-grid .card-img {
    height: 160px;
    background: linear-gradient(135deg, var(--sage-light), var(--terra-light));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40px;
  }
  .articles-grid .card-body {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .articles-grid .card-pilier {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--terra);
    font-weight: 700;
    margin-bottom: 8px;
  }
  .articles-grid .card-title {
    font-family: 'Georgia', serif;
    font-size: 17px;
    font-weight: 400;
    color: var(--slate);
    line-height: 1.35;
    margin-bottom: 8px;
  }
  .articles-grid .card-excerpt {
    font-size: 14px;
    color: var(--slate);
    opacity: 0.8;
    line-height: 1.55;
    flex: 1;
  }
  .articles-grid .card-meta {
    font-size: 12px;
    color: var(--sage);
    margin-top: 14px;
    font-style: italic;
  }

  /* Featured (pleine largeur) */
  .articles-grid .article-card.featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    flex-direction: initial;
  }
  .articles-grid .article-card.featured .card-img {
    height: 100%;
    min-height: 220px;
    font-size: 72px;
  }
  .articles-grid .article-card.featured .card-body {
    padding: 36px;
    justify-content: center;
  }
  .articles-grid .article-card.featured .card-title {
    font-size: 24px;
  }
  .articles-grid .article-card.featured .card-excerpt {
    font-size: 15px;
    line-height: 1.6;
  }

  .journal-empty {
    grid-column: 1 / -1;
    text-align: center;
    font-style: italic;
    color: var(--sage);
    padding: 60px 20px;
  }

  @media (max-width: 900px) {
    .articles-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 700px) {
    .journal-header { padding: 120px 20px 60px; }
    .journal-header .botanical { opacity: 0.08; }
    .journal-header .top-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }
    .filters-bar { padding: 24px 20px 16px; }
    .filter-pill { font-size: 12px; padding: 6px 14px; }
    .search-btn { margin-left: 0; margin-top: 4px; }
    .articles-grid {
      grid-template-columns: 1fr;
      padding: 24px 20px 72px;
      gap: 20px;
    }
    .articles-grid .article-card.featured {
      grid-template-columns: 1fr;
    }
    .articles-grid .article-card.featured .card-img {
      min-height: 160px;
      font-size: 56px;
    }
    .articles-grid .article-card.featured .card-body { padding: 24px; }
    .articles-grid .article-card.featured .card-title { font-size: 20px; }
  }
</style>
