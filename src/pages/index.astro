---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Parent un jour — Le village">

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-inner">
      <div class="label">Parent un jour</div>
      <h1>Il faut tout un village<br/>pour élever un enfant.</h1>
      <div class="script-line">— bienvenue dans le tien —</div>
      <p class="tagline">
        Un espace d'accompagnement et d'exploration pour les futurs et nouveaux parents.
      </p>
      <div class="buttons">
        <a href="#cta" class="btn btn-primary">Rejoindre le village</a>
      </div>
    </div>
  </section>

  <!-- ===== VILLAGE ===== -->
  <section class="village" id="village">
    <div class="container">
      <div class="section-label key">Le cœur du projet</div>
      <blockquote>
        «&nbsp;Être parent ne devrait jamais se faire seul·e.<br/>
        Et pourtant, nous le vivons presque tous·tes ainsi.&nbsp;»
      </blockquote>
      <cite>— ET C'EST POUR ÇA QUE CE VILLAGE EXISTE —</cite>
    </div>
  </section>

  <!-- ===== QUI JE SUIS ===== -->
  <section class="who" id="qui">
    <div class="container">
      <div class="who-grid">
        <div class="who-image">
          <img src={`${base}assets/home.jpg`} alt="Pascaline souriante, debout devant un mur de bois clair avec un eucalyptus et un vase de pampas" loading="lazy" />
        </div>
        <div class="who-text">
          <div class="section-label key">La voix derrière le village</div>
          <h2>Je m'appelle Pascaline.</h2>
          <div class="who-sub">future naturopathe, maman, curieuse et passionnée.</div>
          <p>
            J'ai traversé la parentalité par la face cachée :
            la dépression prénatale, des accouchements difficiles,
            l'hypervigilance, la solitude qui serre la poitrine à 3h du matin.
          </p>
          <p>
            J'ai appris une chose essentielle : <em>personne ne devrait traverser ça seul·e.</em>
          </p>
          <p>
            Alors j'ai commencé à construire le village que j'aurais voulu avoir.
            Pour toi. Pour nous. Pour celles et ceux qui viendront après.
          </p>
          <div class="signature">— Pascaline</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VALEURS ===== -->
  <section class="valeurs">
    <div class="container">
      <div class="section-label key">Mes valeurs</div>
      <h2 class="section-title">Ce qui me guide</h2>
      <div class="section-subtitle">à chaque mot, à chaque partage</div>
      <div class="valeurs-grid">
        <div class="valeur">
          <div class="valeur-number">01</div>
          <div class="valeur-title">Soutien</div>
          <div class="valeur-desc">Un espace éducatif pour accompagner et explorer. On prend ce qui nous parle, on laisse ce qui ne résonne pas.</div>
        </div>
        <div class="valeur">
          <div class="valeur-number">02</div>
          <div class="valeur-title">Légitimité</div>
          <div class="valeur-desc">Chaque parcours est valide. Tes choix, c'est toi qui les fais. Et ils méritent d'être respectés.</div>
        </div>
        <div class="valeur">
          <div class="valeur-number">03</div>
          <div class="valeur-title">Curiosité</div>
          <div class="valeur-desc">On reste ouvert·es, on questionne, on évolue. La parentalité, comme la science, est en mouvement.</div>
        </div>
        <div class="valeur">
          <div class="valeur-number">04</div>
          <div class="valeur-title">Engagement</div>
          <div class="valeur-desc">Du contenu vérifié, des sources fiables, une information qui évolue avec la recherche.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== LES 3 AXES ===== -->
  <section class="axes" id="axes">
    <div class="axes-inner">
      <div class="axes-head">
        <div class="script-line">— par où commencer —</div>
        <h2>Trois chemins, pour t'accompagner</h2>
      </div>
      <div class="axes-grid">

        <a href={`${base}le-village/creer-son-village/`} class="axis-card">
          <div class="axis-num">01</div>
          <h3>Créer son village</h3>
          <div class="axis-sub">avant bébé, s'entourer</div>
          <p>Identifier les 5 personnes qui compteront, poser les bases et bâtir le cercle qui te portera — bien avant l'arrivée.</p>
          <span class="axis-link">Explorer</span>
        </a>

        <a href={`${base}le-village/couple-coparent/`} class="axis-card">
          <div class="axis-num">02</div>
          <h3>Couple &amp; coparent</h3>
          <div class="axis-sub">s'organiser, se parler, charge mentale</div>
          <p>Garder le lien, partager l'invisible, oser les conversations difficiles. Devenir parents sans se perdre l'un l'autre.</p>
          <span class="axis-link">Explorer</span>
        </a>

        <a href={`${base}le-village/postnatal/`} class="axis-card">
          <div class="axis-num">03</div>
          <h3>Le postnatal</h3>
          <div class="axis-sub">la matrescence, devenir parent</div>
          <p>Les trois premières années. Le corps, l'identité, le quotidien — tout ce que tu découvres de jour en jour.</p>
          <span class="axis-link">Explorer</span>
        </a>

      </div>
    </div>
  </section>

  <!-- ===== PROMESSE ===== -->
  <section class="promesse">
    <div class="container">
      <div class="section-label">Ma promesse</div>
      <div class="promesse-quote">
        Avec Parent un jour, <strong>tu ne pars jamais les mains vides.</strong>
      </div>
      <p class="promesse-sub">
        Un post = une solution concrète à appliquer, ou des idées à explorer —
        pour ton quotidien et pour nourrir ta réflexion.
      </p>
    </div>
  </section>

  <!-- ===== RESSOURCES ===== -->
  <section class="ressources" id="ressources">
    <div class="container">
      <div class="section-label">Ressources</div>
      <h2 class="section-title">Des repères, pour t'appuyer</h2>
      <div class="section-subtitle">— celles qui m'ont portée, qui pourront te porter aussi —</div>
      <div class="ressources-grid">

        <div class="ressource-card">
          <span class="ressource-icon" aria-hidden="true">🏥</span>
          <div class="ressource-title">Sites fiables</div>
          <div class="ressource-intro">Des sources validées et reconnues.</div>
          <ul class="ressource-list">
            <li><a href="https://naitreetgrandir.com/fr/" target="_blank" rel="noopener"><strong>Naître et grandir</strong><span>portail québécois pour les 0-8 ans</span></a></li>
            <li><a href="https://nourri-source.org/" target="_blank" rel="noopener"><strong>Nourri-Source</strong><span>soutien à l'allaitement au Québec</span></a></li>
            <li><a href="https://toimoibebe.ca/" target="_blank" rel="noopener"><strong>Toi, Moi, Bébé</strong><span>bien-être parental en ligne</span></a></li>
          </ul>
        </div>

        <div class="ressource-card">
          <span class="ressource-icon" aria-hidden="true">📚</span>
          <div class="ressource-title">Livres</div>
          <div class="ressource-intro">Ceux qui m'ont portée à 3h du matin.</div>
          <ul class="ressource-list">
            <li><strong>Le 4e trimestre de la grossesse</strong><span>Ingrid Bayot</span></li>
            <li><strong>Soyez l'expert de votre bébé</strong><span>Mélanie Bilodeau</span></li>
            <li><strong>Pour une enfance heureuse</strong><span>Dr Catherine Gueguen</span></li>
          </ul>
        </div>

        <div class="ressource-card">
          <span class="ressource-icon" aria-hidden="true">🎧</span>
          <div class="ressource-title">Podcasts</div>
          <div class="ressource-intro">Des voix qui font du bien.</div>
          <ul class="ressource-list">
            <li><a href="https://www.cavamaman.com/" target="_blank" rel="noopener"><strong>Ça va maman</strong><span>Dre Lory Zephyr — Québec</span></a></li>
            <li><a href="https://lamatrescence.fr/" target="_blank" rel="noopener"><strong>La Matrescence</strong><span>Clémentine Sarlat — France</span></a></li>
            <li><a href="https://www.europe1.fr/emissions/sage-meuf-le-podcast-maternite-qui-vous-accompagne-pendant-votre-grossesse-et-apres-laccouchement" target="_blank" rel="noopener"><strong>Sage-Meuf</strong><span>Anna Roy — France</span></a></li>
          </ul>
        </div>

      </div>
      <p class="ressources-note">
        <a href={`${base}ressources/`} class="ressources-more">Livres, podcasts &amp; plus — découvrir toutes les ressources →</a>
      </p>
    </div>
  </section>

  <!-- ===== ENSEMBLE ===== -->
  <section class="ensemble">
    <div class="ensemble-inner">
      <div class="section-label">En couple, en solo, ensemble</div>
      <p>
        Devenir parent, ce n'est pas qu'une aventure individuelle —
        c'est un chemin qui transforme le couple, la famille, et chacun·e d'entre nous.
      </p>
      <span class="script">ici, on prend soin de l'ensemble.</span>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta" id="cta">
    <div class="container">
      <h2>Tu n'es pas seul·e.</h2>
      <div class="script-line">tu n'as pas à l'être.</div>
      <p>
        Rejoins-moi sur Instagram — là où le village vit au quotidien.
        Des questions qu'on n'ose pas poser, des gestes doux, des sources fiables,
        et de la bienveillance. Toujours.
      </p>
      <a href="https://www.instagram.com/parent.un.jour" class="btn btn-primary" target="_blank" rel="noopener">Me suivre sur Instagram</a>
    </div>
  </section>

</Layout>

<style is:global>
  /* ===== VILLAGE QUOTE ===== */
  .village {
    background: var(--cream);
    text-align: center;
  }
  .village blockquote {
    font-family: 'Georgia', serif;
    font-size: clamp(24px, 3.5vw, 36px);
    line-height: 1.4; color: var(--slate);
    font-style: italic;
    max-width: 820px; margin: 0 auto;
  }
  .village cite {
    display: block; margin-top: 24px;
    font-family: 'Lato', sans-serif;
    font-size: 13px; letter-spacing: 2px;
    color: var(--sage-ink); font-style: normal;
    text-transform: uppercase;
    font-weight: 700;
  }

  /* ===== WHO ===== */
  .who { background: var(--offwhite); }
  .who-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.4fr;
    gap: 80px; align-items: center;
  }
  .who-image {
    aspect-ratio: 4/5;
    max-width: 360px;
    width: 100%;
    margin: 0 auto;
    border-radius: 200px 200px 20px 20px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 30px 60px -30px rgba(58,75,75,.25);
    background: linear-gradient(160deg, var(--sage-light), var(--terra-light));
  }
  .who-image img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .who-image-decor {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(160deg, var(--sage-light), var(--terra-light));
  }
  .who-image-initial {
    font-family: 'La Belle Aurore', cursive;
    font-size: 140px;
    color: var(--terra);
    line-height: 1;
    opacity: 0.55;
  }
  .who-text .section-label { text-align: left; }
  .who-text h2 {
    font-family: 'Georgia', serif;
    font-size: 38px; color: var(--slate);
    font-weight: 400; margin-bottom: 6px;
  }
  .who-text .who-sub {
    font-family: 'La Belle Aurore', cursive;
    color: var(--terra); font-size: 28px;
    margin-bottom: 24px;
  }
  .who-text p { margin-bottom: 16px; font-size: 16px; }
  .who-text .signature {
    font-family: 'La Belle Aurore', cursive;
    color: var(--terra); font-size: 32px;
    margin-top: 20px;
  }
  .who-text .who-more {
    display: inline-block;
    margin-top: 16px;
    font-size: 14px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.8px;
    color: var(--terra-ink);
    text-decoration: none;
    transition: color 0.3s;
  }
  .who-text .who-more:hover { color: var(--slate); }
  @media (max-width: 768px) {
    .who-grid { grid-template-columns: 1fr; gap: 40px; }
  }

  /* ===== VALEURS (4 côte à côte) ===== */
  .valeurs { background: var(--sage-light); }
  .valeurs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .valeur {
    background: var(--white);
    padding: 28px 18px;
    border-radius: 12px;
    text-align: center;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .valeur:hover {
    transform: translateY(-5px);
    box-shadow: 0 18px 36px rgba(92, 106, 115, 0.08);
  }
  .valeur-number {
    font-family: 'Georgia', serif;
    font-size: 28px; color: var(--terra-ink);
    font-weight: 700; margin-bottom: 6px;
  }
  .valeur-title {
    font-family: 'Georgia', serif;
    font-size: 18px; color: var(--slate);
    margin-bottom: 10px;
    font-weight: 700;
  }
  .valeur-desc {
    font-size: 13px; line-height: 1.55;
    color: var(--slate); opacity: 0.9;
  }
  @media (max-width: 980px) {
    .valeurs-grid { grid-template-columns: 1fr; }
  }

  /* ===== AXES ===== */
  .axes {
    background: var(--white);
    padding: 100px 40px;
  }
  .axes-inner { max-width: 1200px; margin: 0 auto; }
  .axes-head { text-align: center; max-width: 680px; margin: 0 auto 64px; }
  .axes-head .script-line {
    font-family: 'La Belle Aurore', cursive;
    color: var(--terra); font-size: 30px;
    margin-bottom: 8px;
  }
  .axes-head h2 {
    font-family: 'Georgia', serif;
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 400; color: var(--slate);
    line-height: 1.15;
  }
  .axes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .axis-card {
    background: var(--offwhite);
    border: 1px solid rgba(168,185,163,.2);
    border-radius: 16px;
    padding: 40px 36px;
    display: flex; flex-direction: column;
    transition: all .25s ease;
    text-decoration: none; color: inherit;
    min-height: 260px;
    position: relative; overflow: hidden;
  }
  .axis-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 24px 48px -24px rgba(58,75,75,.2);
    border-color: var(--terra-light);
  }
  .axis-num {
    font-family: 'La Belle Aurore', cursive;
    color: var(--terra); font-size: 28px;
    margin-bottom: 12px;
  }
  .axis-card h3 {
    font-family: 'Georgia', serif;
    font-size: 28px; font-weight: 400;
    color: var(--slate); margin-bottom: 10px;
    line-height: 1.2;
  }
  .axis-card .axis-sub {
    font-family: 'La Belle Aurore', cursive;
    color: var(--sage-ink); font-size: 20px;
    margin-bottom: 18px;
  }
  .axis-card p {
    color: var(--slate); opacity: .8;
    font-size: 15px; line-height: 1.7;
    margin-bottom: 24px; flex: 1;
  }
  .axis-card .axis-link {
    font-size: 12px; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--terra-ink);
    display: inline-flex; align-items: center; gap: 8px;
  }
  .axis-card .axis-link::after {
    content: '→';
    transition: transform .2s ease;
  }
  .axis-card:hover .axis-link::after { transform: translateX(4px); }
  @media (max-width: 980px) {
    .axes-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .axes-grid { grid-template-columns: 1fr; }
  }

  /* ===== PROMESSE ===== */
  .promesse {
    background: var(--terra-light);
    text-align: center;
  }
  .promesse-quote {
    font-family: 'Georgia', serif;
    font-size: clamp(24px, 3.5vw, 42px);
    line-height: 1.3; color: var(--slate);
    max-width: 800px; margin: 0 auto 20px;
  }
  .promesse-quote strong {
    font-style: italic; color: var(--terra-ink);
    font-weight: 400;
  }
  .promesse-sub {
    font-size: 16px; color: var(--slate);
    max-width: 640px; margin: 0 auto;
  }

  /* ===== RESSOURCES ===== */
  .ressources { background: var(--cream); }
  .ressources-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: stretch;
  }
  .ressource-card {
    background: var(--white);
    padding: 36px 32px;
    border-radius: 14px;
    border: 1px solid rgba(168, 185, 163, 0.2);
    transition: transform 0.3s, box-shadow 0.3s;
    display: flex;
    flex-direction: column;
  }
  .ressource-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 36px rgba(92, 106, 115, 0.08);
  }
  .ressource-icon {
    font-size: 32px; margin-bottom: 14px;
    display: block;
  }
  .ressource-title {
    font-family: 'Georgia', serif;
    font-size: 22px; color: var(--slate);
    font-weight: 700; margin-bottom: 8px;
    line-height: 1.3;
  }
  .ressource-intro {
    font-size: 14px;
    color: var(--slate); opacity: 0.85;
    margin-bottom: 18px;
    font-style: italic;
  }
  .ressource-list {
    list-style: none;
    padding: 0;
  }
  .ressource-list li {
    font-size: 14px;
    color: var(--slate);
    padding: 8px 0;
    border-bottom: 1px dashed rgba(131, 150, 125, 0.25);
    line-height: 1.5;
  }
  .ressource-list li:last-child { border-bottom: none; }
  .ressource-list li strong {
    color: var(--slate);
    font-weight: 700;
  }
  /* Liens invisibles — pas de couleur ni de soulignement */
  .ressource-list li a {
    color: inherit;
    text-decoration: none;
    border: none;
    display: block;
    cursor: pointer;
  }
  .ressource-list li span {
    color: var(--terra-ink);
    opacity: 0.8;
    font-size: 12px;
    display: block;
    margin-top: 2px;
    font-style: italic;
  }
  .ressources-note {
    text-align: center;
    margin-top: 40px;
    font-family: 'Georgia', serif;
    font-style: italic;
    color: var(--sage-ink);
    font-size: 15px;
  }
  .ressources-grid--compact {
    grid-template-columns: repeat(2, 1fr);
    max-width: 960px;
    margin: 0 auto;
  }
  @media (max-width: 960px) {
    .ressources-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .ressources-grid,
    .ressources-grid--compact {
      grid-template-columns: 1fr;
    }
  }
  .ressources-more {
    color: var(--terra-ink);
    font-style: normal;
    font-family: inherit;
    font-weight: 500;
    border-bottom: 1px solid var(--terra-light);
    padding-bottom: 1px;
    text-decoration: none;
  }
  .ressources-more:hover { color: var(--slate); }

  /* ===== ENSEMBLE ===== */
  .ensemble {
    background: var(--white);
    text-align: center;
  }
  .ensemble-inner { max-width: 820px; margin: 0 auto; }
  .ensemble p {
    font-family: 'Georgia', serif;
    font-size: clamp(20px, 2.8vw, 30px);
    line-height: 1.45; color: var(--slate);
    font-style: italic;
  }
  .ensemble .script {
    font-family: 'La Belle Aurore', cursive;
    color: var(--terra);
    font-style: normal;
    font-size: clamp(24px, 3.2vw, 36px);
    margin-top: 18px;
    display: block;
  }

  /* ===== CTA ===== */
  .cta {
    background: var(--slate);
    color: var(--white);
    text-align: center;
  }
  .cta h2 {
    font-family: 'Georgia', serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 400; margin-bottom: 12px;
    color: var(--white);
  }
  .cta .script-line {
    font-family: 'La Belle Aurore', cursive;
    color: var(--terra-light);
    font-size: 28px;
    margin-bottom: 32px;
  }
  .cta p { max-width: 600px; margin: 0 auto 32px; opacity: 0.9; }
  .cta .btn-primary { background: var(--terra); }
  .cta .btn-primary:hover { background: var(--white); color: var(--slate); }
</style>
